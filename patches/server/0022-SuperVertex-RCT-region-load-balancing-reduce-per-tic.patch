-            final java.util.List<LevelChunk> rctChunksToTick =
-                dev.supervertex.SuperVertexConfig.regionizedChunkTicking
-                    ? new java.util.ArrayList<>() : null;
+            // rctChunksBuffer を再利用することで毎 tick の ArrayList アロケーションを回避する
+            final java.util.List<LevelChunk> rctChunksToTick;
+            if (dev.supervertex.SuperVertexConfig.regionizedChunkTicking) {
