From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: wisemanjr4 <mitsuking2003@gmail.com>
Date: Tue, 24 Mar 2026 23:18:10 +0900
Subject: [PATCH] SuperVertex: dynamic randomTickSpeed, tracker buffer reuse,
 spawn throttle fix

- dynamic-random-tick-speed: far chunks get reduced randomTickSpeed
  (configurable near-chunks radius + min-factor, default off)
- Entity tracker: reuse ArrayList buffer to eliminate per-tick GC allocation
- Mob spawn: gate spawnForChunk with willSpawnThisTick so mob-spawn-throttle-ticks
  also skips per-chunk spawn candidate iteration, not just createState

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>

diff --git a/src/main/java/dev/supervertex/SuperVertexConfig.java b/src/main/java/dev/supervertex/SuperVertexConfig.java
index 3eb09f1801a6ece14a6d1039454fa3e0f0e8737f..7fab8222d83784f42939309f1c059e35c5c9b423 100644
--- a/src/main/java/dev/supervertex/SuperVertexConfig.java
+++ b/src/main/java/dev/supervertex/SuperVertexConfig.java
@@ -254,6 +254,48 @@ public class SuperVertexConfig {
         permissionCache = getBoolean("performance.permission-cache", permissionCache);
     }
 
+    // =========================================================
+    // Performance: Dynamic Random Tick Speed
+    // =========================================================
+
+    /**
+     * プレイヤーから遠いチャンクの randomTickSpeed を動的に削減するかどうか。
+     * プレイヤーから {@code dynamicRandomTickSpeedNearChunks} チャンク以内は
+     * 通常の randomTickSpeed、それ以遠は {@code dynamicRandomTickSpeedMinFactor} 倍に削減する。
+     * 広い viewDistance 環境でのメインスレッド負荷を大幅に削減できる。
+     * 遠方のブロック成長・草の広がり等は遅くなるため注意。
+     */
+    public static boolean dynamicRandomTickSpeed = false;
+
+    private static void dynamicRandomTickSpeed() {
+        dynamicRandomTickSpeed = getBoolean("performance.dynamic-random-tick-speed", dynamicRandomTickSpeed);
+    }
+
+    /**
+     * dynamic-random-tick-speed が true の場合、プレイヤーからこのチャンク半径以内は
+     * 通常の randomTickSpeed を維持する。それ以遠は min-factor 倍まで削減される。
+     * デフォルト: 5 (プレイヤー周囲 5 チャンク以内はフルスピード)
+     */
+    public static int dynamicRandomTickSpeedNearChunks = 5;
+
+    private static void dynamicRandomTickSpeedNearChunks() {
+        dynamicRandomTickSpeedNearChunks = getInt("performance.dynamic-random-tick-speed-near-chunks", dynamicRandomTickSpeedNearChunks);
+        if (dynamicRandomTickSpeedNearChunks < 0) dynamicRandomTickSpeedNearChunks = 0;
+    }
+
+    /**
+     * dynamic-random-tick-speed が true の場合、遠方チャンクに適用する randomTickSpeed の最小係数。
+     * 例: 0.25 = 通常速度の 25%。0.0 = ランダムtick完全停止。
+     * デフォルト: 0.25
+     */
+    public static double dynamicRandomTickSpeedMinFactor = 0.25;
+
+    private static void dynamicRandomTickSpeedMinFactor() {
+        dynamicRandomTickSpeedMinFactor = getDouble("performance.dynamic-random-tick-speed-min-factor", dynamicRandomTickSpeedMinFactor);
+        if (dynamicRandomTickSpeedMinFactor < 0.0) dynamicRandomTickSpeedMinFactor = 0.0;
+        if (dynamicRandomTickSpeedMinFactor > 1.0) dynamicRandomTickSpeedMinFactor = 1.0;
+    }
+
     // =========================================================
     // 設定の再読み込み
     // =========================================================
