-              || block instanceof net.minecraft.world.level.block.BaseFireBlock);
+              || block instanceof net.minecraft.world.level.block.BaseFireBlock
+              || block instanceof net.minecraft.world.level.block.LiquidBlock    // 水・溶岩: 隣接チャンクread→deadlock
