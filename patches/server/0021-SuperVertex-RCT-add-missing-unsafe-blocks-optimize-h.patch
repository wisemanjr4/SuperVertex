@@ -136,21 +154,76 @@ public final class RegionizedChunkTicker {
     public static final java.util.concurrent.ConcurrentLinkedQueue<java.util.ArrayDeque<Runnable>> ALL_DEFERRED =
             new java.util.concurrent.ConcurrentLinkedQueue<>();
 
+    // =========================================================
+    // ブロック安全性キャッシュ — 22回 instanceof → 1回配列アクセスに最適化
+    // =========================================================
+
+    /**
+     * ブロックレジストリ ID をインデックスとする安全性フラグ配列。
+     * true = RCT ワーカーで安全に randomTick 可能。
+     * サーバー起動時（ブロックレジストリ確定後）に {@link #initBlockSafetyCache()} で初期化される。
+     */
+    private static volatile boolean[] blockSafetyCache = null;
+
+    /**
+     * ブロックレジストリが確定した後に呼び出してキャッシュを初期化する。
+     * MinecraftServer 起動シーケンスの適切なタイミングで一度だけ呼ぶこと。
+     */
+    public static void initBlockSafetyCache() {
+        net.minecraft.core.Registry<net.minecraft.world.level.block.Block> reg =
+                net.minecraft.core.registries.BuiltInRegistries.BLOCK;
+        boolean[] cache = new boolean[reg.size()];
+        for (int i = 0; i < cache.length; i++) {
+            net.minecraft.world.level.block.Block b = reg.byId(i);
+            cache[i] = b != null && computeIsBlockSafe(b);
+        }
+        blockSafetyCache = cache;
+        org.apache.logging.log4j.LogManager.getLogger("SuperVertex/RCT")
+                .info("Block safety cache initialized: {} blocks ({} unsafe)",
+                        cache.length,
+                        (int) java.util.stream.IntStream.range(0, cache.length).filter(i -> !cache[i]).count());
+    }
+
     /**
      * ブロックが RCT ワーカースレッドから安全に randomTick できるかを返す。
      *
-     * 以下のブロックは randomTick 内で CraftEventFactory（Bukkit イベント）を呼ぶため
-     * メインスレッドへの Deferred 実行が必要:
+     * キャッシュ初期化後はレジストリ ID での配列アクセス（O(1)) になる。
+     * キャッシュ未初期化時（起動直後）は instanceof チェックにフォールバック。
+     *
+     * @return true = 並列実行安全、false = メインスレッドへ Defer が必要
+     */
+    public static boolean isBlockSafeForRCT(net.minecraft.world.level.block.Block block) {
+        boolean[] cache = blockSafetyCache;
+        if (cache != null) {
+            int id = net.minecraft.core.registries.BuiltInRegistries.BLOCK.getId(block);
+            if (id >= 0 && id < cache.length) return cache[id];
+        }
+        return computeIsBlockSafe(block);
+    }
+
+    /**
+     * instanceof チェックによる安全性判定（キャッシュ構築・フォールバック用）。
+     *
+     * 危険なブロック一覧（randomTick 内で Bukkit イベントまたはクロスチャンク read を行う）:
      *   VineBlock, TurtleEggBlock, SweetBerryBushBlock, StemBlock (MelonStem/PumpkinStem),
      *   SugarCaneBlock, SpreadingSnowyDirtBlock (Grass/Mycelium), SnowLayerBlock,
      *   LeavesBlock, CropBlock (Wheat/Carrot/Potato 等), CocoaBlock, ChorusFlowerBlock,
      *   CactusBlock, BambooStalkBlock, BambooSaplingBlock, RedStoneOreBlock,
      *   GrowingPlantHeadBlock (Kelp/TwistingVines/WeepingVines 等), NetherWartBlock,
-     *   BaseFireBlock (FireBlock)
-     *
-     * @return true = 並列実行安全、false = メインスレッドへ Defer が必要
+     *   BaseFireBlock (FireBlock),
