+     *   MushroomBlock — ±4範囲 getBlockState (クロスチャンク) + Bukkit event
+     *   NetherPortalBlock — エンティティスポーン (Bukkit event)
+     *   IceBlock — CraftEventFactory.callBlockFadeEvent (Bukkit event)
+     *   FarmBlock — ±4範囲 isNearWater (クロスチャンク) + Bukkit event
+     *   NyliumBlock — CraftEventFactory.callBlockFadeEvent (Bukkit event)
+     *   ChangeOverTimeBlock (銅ブロック酸化系) — ±4 Manhattan getBlockState + handleBlockFormEvent (Bukkit)
+     *   PointedDripstoneBlock — 縦方向多段スキャン getBlockState + handleBlockFormEvent (Bukkit)
+     *   SaplingBlock — StructureGrowEvent (Bukkit event)
      */
-    public static boolean isBlockSafeForRCT(net.minecraft.world.level.block.Block block) {
+    private static boolean computeIsBlockSafe(net.minecraft.world.level.block.Block block) {
         return !(block instanceof net.minecraft.world.level.block.VineBlock
               || block instanceof net.minecraft.world.level.block.TurtleEggBlock
               || block instanceof net.minecraft.world.level.block.SweetBerryBushBlock
@@ -168,7 +241,18 @@ public final class RegionizedChunkTicker {
               || block instanceof net.minecraft.world.level.block.RedStoneOreBlock
               || block instanceof net.minecraft.world.level.block.GrowingPlantHeadBlock
