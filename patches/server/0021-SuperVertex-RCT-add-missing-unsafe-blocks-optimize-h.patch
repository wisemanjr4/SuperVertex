-                if (neighborIdx >= 0) {
-                    union(parent, rank, i, neighborIdx);
-                }
-            }
+            int cx = pos.x, cz = pos.z;
+            int n;
+            if ((n = reusePosIdx.get(ChunkPos.asLong(cx + 1, cz    ))) >= 0) union(parent, rank, i, n);
+            if ((n = reusePosIdx.get(ChunkPos.asLong(cx - 1, cz    ))) >= 0) union(parent, rank, i, n);
+            if ((n = reusePosIdx.get(ChunkPos.asLong(cx,     cz + 1))) >= 0) union(parent, rank, i, n);
+            if ((n = reusePosIdx.get(ChunkPos.asLong(cx,     cz - 1))) >= 0) union(parent, rank, i, n);
         }
 
-        // ルートでグループ化
-        it.unimi.dsi.fastutil.ints.Int2ObjectOpenHashMap<List<LevelChunk>> regionMap =
