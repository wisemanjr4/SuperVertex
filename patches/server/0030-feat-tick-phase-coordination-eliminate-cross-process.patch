From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: wisemanjr4 <mitsuking2003@gmail.com>
Date: Mon, 30 Mar 2026 02:10:39 +0900
Subject: [PATCH] feat: tick phase coordination - eliminate cross-process tick
 spikes

Add SuperVertexTickScheduler with per-process phase offsets (0-3).
All periodic processes now use isActiveTick(hash, phaseOffset, period, tick)
so they don't coincide on the same tick:

  PHASE_MOB_SPAWN=0   Mob spawn (per-chunk distributed)
  PHASE_CHUNK_TICK=1  Chunk tick spread
  PHASE_BE_THROTTLE=2 Block entity batch tick
  PHASE_DEEP_SLEEP=3  Entity deep sleep

Key change: mob spawnForChunk converted from global (all chunks on one tick)
to per-chunk scheduling via isActiveTick. createState still refreshes every
throttle ticks; spawnForChunk distributes across ticks using chunk hash.
Eliminates the concentrated spawn spike that caused 143ms max MSPT.

diff --git a/src/main/java/dev/supervertex/SuperVertexTickScheduler.java b/src/main/java/dev/supervertex/SuperVertexTickScheduler.java
new file mode 100644
index 0000000000000000000000000000000000000000..d38054b491eacd39e5bb39a219e90d02458e6c37
--- /dev/null
+++ b/src/main/java/dev/supervertex/SuperVertexTickScheduler.java
@@ -0,0 +1,59 @@
+package dev.supervertex;
+
+/**
+ * SuperVertex Tick Phase Scheduler
+ *
+ * 異なる周期処理に互いに異なる位相オフセットを割り当て、
+ * 複数処理が同一 tick に集中してスパイクを起こすのを防ぐ。
+ *
+ * 例: 全処理が period=4 の場合、オフセット 0〜3 を割り当てると
+ *     各 tick に 1 処理ずつ均等に分散する。
+ *
+ *   tick % 4 == 0  →  Mob Spawn (PHASE_MOB_SPAWN=0)
+ *   tick % 4 == 1  →  Chunk Tick Spread (PHASE_CHUNK_TICK=1)
+ *   tick % 4 == 2  →  BE Batch (PHASE_BE_THROTTLE=2)
+ *   tick % 4 == 3  →  Entity Deep Sleep (PHASE_DEEP_SLEEP=3)
+ */
+public final class SuperVertexTickScheduler {
+
+    private SuperVertexTickScheduler() {}
+
+    // =========================================================
+    // 各処理の位相オフセット定数
+    // =========================================================
+
+    /** Mob Spawn per-chunk 分散の位相オフセット */
+    public static final int PHASE_MOB_SPAWN   = 0;
+
+    /** Chunk Tick Spread の位相オフセット */
+    public static final int PHASE_CHUNK_TICK  = 1;
+
+    /** Block Entity Batch Tick の位相オフセット */
+    public static final int PHASE_BE_THROTTLE = 2;
+
+    /** Entity Deep Sleep の位相オフセット */
+    public static final int PHASE_DEEP_SLEEP  = 3;
+
+    // =========================================================
+    // 判定ヘルパー
+    // =========================================================
+
+    /**
+     * 要素固有のハッシュ値と位相オフセットを使って、今 tick がこの要素の当番かを判定する。
+     *
+     * 計算式: (currentTick % period) == ((|hash| + phaseOffset) % period)
+     *
+     * 同じ period を持つ複数の処理に異なる phaseOffset を設定することで、
+     * 処理が同一 tick に集中しなくなる。
+     *
+     * @param hash        要素固有ハッシュ（entity ID, pos.hashCode(), chunk hash 等）
+     * @param phaseOffset プロセスの位相オフセット（PHASE_* 定数を使用）
+     * @param period      周期（tick 数）。1 以下なら常に true
+     * @param currentTick 現在の tick カウント
+     * @return true = 今 tick がこの要素の当番
+     */
+    public static boolean isActiveTick(int hash, int phaseOffset, int period, long currentTick) {
+        if (period <= 1) return true;
+        return (currentTick % period) == ((Math.abs(hash) + phaseOffset) % period);
+    }
+}
