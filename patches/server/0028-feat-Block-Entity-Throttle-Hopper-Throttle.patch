From: wisemanjr4 <mitsuking2003@gmail.com>
Date: Mon, 30 Mar 2026 01:38:44 +0900
Subject: [PATCH] feat: Block Entity Throttle + Hopper Throttle

Skip ticking far-from-player block entities to reduce main thread load.
- BE Throttle: furnace/blast_furnace/smoker/brewing_stand/campfire/soul_campfire
  skip when beyond blockEntityThrottleNearChunks (default 4 chunks), tick
  every blockEntityThrottleTickRate ticks (default 4, 75% reduction).
- Hopper Throttle: same distance check but conservative tick rate 2 (50%
  reduction) to minimize impact on item transport farms.
Player positions snapshotted once per tickBlockEntities() call into a
reused int[] array. Pos hashCode staggering distributes skipped ticks
evenly across all ticks (same approach as Entity Deep Sleep).

diff --git a/src/main/java/dev/supervertex/SuperVertexConfig.java b/src/main/java/dev/supervertex/SuperVertexConfig.java
index 10f8ad77934d1f8ff96e765c6f61f39117a8c2d9..7b7433282d7c3262c2726712fcfb57b7292f75c5 100644
--- a/src/main/java/dev/supervertex/SuperVertexConfig.java
+++ b/src/main/java/dev/supervertex/SuperVertexConfig.java
@@ -337,6 +337,84 @@ public class SuperVertexConfig {
         if (entityDeepSleepTickRate < 1) entityDeepSleepTickRate = 1;
     }
 
+    // =========================================================
+    // Block Entity Throttle
+    // =========================================================
+
+    /**
+     * プレイヤーから遠い溶鉱炉・醸造台・かまど・キャンプファイア等の
+     * Block Entity tick を間引くか。
+     * 遠方の未使用 BE が多い環境（放置施設等）でメインスレッド負荷を削減する。
+     * デフォルト: true
+     */
+    public static boolean blockEntityThrottle = true;
+
+    private static void blockEntityThrottle() {
+        blockEntityThrottle = getBoolean("performance.block-entity-throttle", blockEntityThrottle);
+    }
+
+    /**
+     * Block Entity Throttle: フルスピード tick を維持するプレイヤーからの半径（チャンク数）。
+     * デフォルト: 4
+     */
+    public static int blockEntityThrottleNearChunks = 4;
+
+    private static void blockEntityThrottleNearChunks() {
+        blockEntityThrottleNearChunks = getInt("performance.block-entity-throttle-near-chunks", blockEntityThrottleNearChunks);
+        if (blockEntityThrottleNearChunks < 0) blockEntityThrottleNearChunks = 0;
+    }
+
+    /**
+     * Block Entity Throttle: 遠方 BE が tick される間隔（N tick に 1 回）。
+     * 例: 4 = 4 tick に 1 回（75% 削減）。BE 座標ハッシュでスタガリングして負荷を均等分散。
+     * デフォルト: 4
+     */
+    public static int blockEntityThrottleTickRate = 4;
+
+    private static void blockEntityThrottleTickRate() {
+        blockEntityThrottleTickRate = getInt("performance.block-entity-throttle-tick-rate", blockEntityThrottleTickRate);
+        if (blockEntityThrottleTickRate < 1) blockEntityThrottleTickRate = 1;
+    }
+
+    // =========================================================
+    // Hopper Throttle
+    // =========================================================
+
+    /**
+     * プレイヤーから遠いホッパーの tick を間引くか。
+     * BE Throttle より保守的なデフォルト設定（2 tick に 1 回）で、
+     * ファームへの影響を最小限に抑えつつホッパーチェーンの負荷を削減する。
+     * デフォルト: true
+     */
+    public static boolean hopperThrottle = true;
+
+    private static void hopperThrottle() {
+        hopperThrottle = getBoolean("performance.hopper-throttle", hopperThrottle);
+    }
+
+    /**
+     * Hopper Throttle: フルスピードを維持するプレイヤーからの半径（チャンク数）。
+     * デフォルト: 4
+     */
+    public static int hopperThrottleNearChunks = 4;
+
+    private static void hopperThrottleNearChunks() {
+        hopperThrottleNearChunks = getInt("performance.hopper-throttle-near-chunks", hopperThrottleNearChunks);
+        if (hopperThrottleNearChunks < 0) hopperThrottleNearChunks = 0;
+    }
+
+    /**
+     * Hopper Throttle: 遠方ホッパーが tick される間隔（N tick に 1 回）。
+     * 2 = アイテム転送速度が半分。プレイヤー不在の倉庫・自動化施設向け。
+     * デフォルト: 2
+     */
+    public static int hopperThrottleTickRate = 2;
+
+    private static void hopperThrottleTickRate() {
+        hopperThrottleTickRate = getInt("performance.hopper-throttle-tick-rate", hopperThrottleTickRate);
+        if (hopperThrottleTickRate < 1) hopperThrottleTickRate = 1;
+    }
+
     // =========================================================
     // 設定の再読み込み
     // =========================================================
