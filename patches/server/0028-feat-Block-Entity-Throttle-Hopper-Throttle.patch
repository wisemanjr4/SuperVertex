+    // SuperVertex start - Block Entity Throttle / Hopper Throttle
+    // tickBlockEntities() 内でプレイヤー距離チェックに使うスナップショット（再利用配列）
+    private int[] beThrottlePlayerChunkXZ = new int[0];
+    private int   beThrottlePlayerCount   = 0;
+
+    /**
+     * Block Entity の種別ごとのスロットル判定。
+     * 遠方かつ今 tick にスロットル対象なら true を返す（= tick をスキップ）。
+     *
+     * スロットル対象 BE:
+     *   furnace / blast_furnace / smoker / brewing_stand / campfire / soul_campfire
+     *   → blockEntityThrottle 設定で制御
+     *   hopper → hopperThrottle 設定で制御（保守的なレート）
+     */
+    private boolean shouldThrottleBlockEntity(TickingBlockEntity tbe) {
+        final String type = tbe.getType();
+        final boolean isHopper = "minecraft:hopper".equals(type);
+        final boolean isSafeBe;
+        if (isHopper) {
+            if (!dev.supervertex.SuperVertexConfig.hopperThrottle) return false;
+            isSafeBe = true;
+        } else if (dev.supervertex.SuperVertexConfig.blockEntityThrottle) {
+            isSafeBe = "minecraft:furnace".equals(type)
+                    || "minecraft:blast_furnace".equals(type)
+                    || "minecraft:smoker".equals(type)
+                    || "minecraft:brewing_stand".equals(type)
+                    || "minecraft:campfire".equals(type)
+                    || "minecraft:soul_campfire".equals(type);
+        } else {
+            return false;
+        }
+        if (!isSafeBe) return false;
+
+        // プレイヤー近接チェック
+        final int nearChunks = isHopper
+                ? dev.supervertex.SuperVertexConfig.hopperThrottleNearChunks
+                : dev.supervertex.SuperVertexConfig.blockEntityThrottleNearChunks;
+        final BlockPos pos = tbe.getPos();
+        final int chunkX = net.minecraft.core.SectionPos.blockToSectionCoord(pos.getX());
+        final int chunkZ = net.minecraft.core.SectionPos.blockToSectionCoord(pos.getZ());
+        for (int i = 0; i < beThrottlePlayerCount; i++) {
+            final int dx = Math.abs(beThrottlePlayerChunkXZ[i * 2]     - chunkX);
+            final int dz = Math.abs(beThrottlePlayerChunkXZ[i * 2 + 1] - chunkZ);
+            if (Math.max(dx, dz) <= nearChunks) return false; // 近くにプレイヤーがいる → スキップしない
+        }
+
+        // 遠方 — 座標ハッシュでスタガリングして負荷を各 tick に均等分散
+        final int tickRate = isHopper
+                ? dev.supervertex.SuperVertexConfig.hopperThrottleTickRate
+                : dev.supervertex.SuperVertexConfig.blockEntityThrottleTickRate;
+        final long currentTick = net.minecraft.server.MinecraftServer.currentTick;
+        return (currentTick % tickRate) != (Math.abs(pos.hashCode()) % tickRate);
+    }
+    // SuperVertex end - Block Entity Throttle / Hopper Throttle
+
     protected void tickBlockEntities() {
         //ProfilerFiller gameprofilerfiller = this.getProfiler(); // Purpur
 
