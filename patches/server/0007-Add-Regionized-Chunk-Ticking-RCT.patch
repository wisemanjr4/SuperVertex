From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: wisemanjr4 <mitsuking2003@gmail.com>
Date: Tue, 24 Feb 2026 20:23:15 +0900
Subject: [PATCH] Add Regionized Chunk Ticking (RCT)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- RegionizedChunkTicker: Union-Find でチャンクを隣接グループに分割し
  ForkJoinPool で並列 tickChunk を実行する
- ServerLevel: tickChunk 内でスレッドローカルな MutableBlockPos / RandomSource
  を使用する (RCT ワーカースレッド用)
- ServerChunkCache: Phase1 (逐次: スポーン/inhabitedTime) と
  Phase2 (並列: tickChunk) に分離
- SuperVertexConfig: performance.regionized-chunk-ticking 設定を追加

安全性: 隣接チャンクは必ず同一リージョンに属するため
リージョン間に最低 1 チャンクの隙間が保証される。
DivineMC/CanvasMC の実装を参考。

diff --git a/src/main/java/dev/supervertex/RegionizedChunkTicker.java b/src/main/java/dev/supervertex/RegionizedChunkTicker.java
new file mode 100644
index 0000000000000000000000000000000000000000..3ad1a91afbf2aececa06722e6c2dbef58b1cdffb
--- /dev/null
+++ b/src/main/java/dev/supervertex/RegionizedChunkTicker.java
@@ -0,0 +1,156 @@
+package dev.supervertex;
+
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.chunk.LevelChunk;
+
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.List;
+import java.util.function.Consumer;
+
+/**
+ * Regionized Chunk Ticking (RCT) for SuperVertex.
+ *
+ * プレイヤー周辺のチャンクを隣接グループ（リージョン）に分割し、
+ * 各リージョンを並列 tick することでマルチコア CPU を活用する。
+ *
+ * 安全性保証:
+ *   Union-Find で隣接チャンクは必ず同一リージョンに収まるため、
+ *   異なるリージョン間には最低 1 チャンクの隙間が存在する。
+ *   これにより並列 tickChunk の境界データ競合を回避する。
+ *
+ * 実装参考: DivineMC (CanvasMC fork)
+ */
+public final class RegionizedChunkTicker {
+
+    private RegionizedChunkTicker() {}
+
+    /**
+     * RCT ワーカースレッドであることを示すスレッドローカルフラグ。
+     * ServerLevel.tickChunk() 内でスレッドローカルリソースを使うかどうかの判定に用いる。
+     */
+    public static final ThreadLocal<Boolean> IN_RCT_CONTEXT = ThreadLocal.withInitial(() -> false);
+
+    /** RCT ワーカー用スレッドローカル MutableBlockPos */
+    public static final ThreadLocal<net.minecraft.core.BlockPos.MutableBlockPos> RCT_BLOCK_POS =
+            ThreadLocal.withInitial(net.minecraft.core.BlockPos.MutableBlockPos::new);
+
+    /** RCT ワーカー用スレッドローカル RandomSource */
+    public static final ThreadLocal<net.minecraft.util.RandomSource> RCT_RANDOM =
+            ThreadLocal.withInitial(() -> new io.papermc.paper.util.math.ThreadUnsafeRandom(
+                    java.util.concurrent.ThreadLocalRandom.current().nextLong()));
+
+    // =========================================================
+    // Union-Find 実装
+    // =========================================================
+
+    private static int find(int[] parent, int x) {
+        // パス半減による高速化
+        while (parent[x] != x) {
+            parent[x] = parent[parent[x]];
+            x = parent[x];
+        }
+        return x;
+    }
+
+    private static void union(int[] parent, int[] rank, int a, int b) {
+        int ra = find(parent, a);
+        int rb = find(parent, b);
+        if (ra == rb) return;
+        // ランクによる結合
+        if (rank[ra] < rank[rb]) { int t = ra; ra = rb; rb = t; }
+        parent[rb] = ra;
+        if (rank[ra] == rank[rb]) rank[ra]++;
+    }
+
+    // =========================================================
+    // リージョン構築
+    // =========================================================
+
+    /**
+     * 与えられたチャンクリストを「隣接チャンクを同一グループ」にまとめる Union-Find でリージョンに分割する。
+     * 返却リストの各要素が 1 リージョンのチャンク一覧。
+     */
+    public static List<List<LevelChunk>> buildRegions(List<LevelChunk> chunks) {
+        int size = chunks.size();
+        if (size == 0) return Collections.emptyList();
+        if (size == 1) return Collections.singletonList(chunks);
+
+        // チャンク位置 → インデックスの高速マップ (fastutil Long2Int)
+        it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap posToIndex =
+                new it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap(size * 2, 0.5f);
+        posToIndex.defaultReturnValue(-1);
+        for (int i = 0; i < size; i++) {
+            posToIndex.put(chunks.get(i).getPos().toLong(), i);
+        }
+
+        // Union-Find 初期化
+        int[] parent = new int[size];
+        int[] rank   = new int[size];
+        for (int i = 0; i < size; i++) parent[i] = i;
+
+        // 4 方向隣接チャンクを結合
+        final int[] DX = {1, -1, 0, 0};
+        final int[] DZ = {0, 0, 1, -1};
+        for (int i = 0; i < size; i++) {
+            ChunkPos pos = chunks.get(i).getPos();
+            for (int d = 0; d < 4; d++) {
+                int neighborIdx = posToIndex.get(ChunkPos.asLong(pos.x + DX[d], pos.z + DZ[d]));
+                if (neighborIdx >= 0) {
+                    union(parent, rank, i, neighborIdx);
+                }
+            }
+        }
+
+        // ルートでグループ化
+        it.unimi.dsi.fastutil.ints.Int2ObjectOpenHashMap<List<LevelChunk>> regionMap =
+                new it.unimi.dsi.fastutil.ints.Int2ObjectOpenHashMap<>();
+        for (int i = 0; i < size; i++) {
+            regionMap.computeIfAbsent(find(parent, i), k -> new ArrayList<>()).add(chunks.get(i));
+        }
+
+        return new ArrayList<>(regionMap.values());
+    }
+
+    // =========================================================
+    // 並列 tick 実行
+    // =========================================================
+
+    /**
+     * リージョンリストを並列で tick する。
+     * リージョンが 1 つのみの場合は逐次実行にフォールバックする。
+     */
+    public static void tickRegionsParallel(List<List<LevelChunk>> regions, Consumer<LevelChunk> tickAction) {
+        if (regions.isEmpty()) return;
+
+        if (regions.size() == 1) {
+            // リージョン 1 つ → 並列化不要
+            for (LevelChunk chunk : regions.get(0)) {
+                tickAction.accept(chunk);
+            }
+            return;
+        }
+
+        try {
+            SuperVertexThreadPool.TRACKER_POOL.submit(() ->
+                regions.parallelStream().forEach(region -> {
+                    IN_RCT_CONTEXT.set(true);
+                    try {
+                        for (LevelChunk chunk : region) {
+                            tickAction.accept(chunk);
+                        }
+                    } finally {
+                        IN_RCT_CONTEXT.set(false);
+                    }
+                })
+            ).get();
+        } catch (java.util.concurrent.ExecutionException | InterruptedException e) {
+            // エラー時はメインスレッドで逐次フォールバック
+            for (List<LevelChunk> region : regions) {
+                for (LevelChunk chunk : region) {
+                    tickAction.accept(chunk);
+                }
+            }
+        }
+    }
+}
