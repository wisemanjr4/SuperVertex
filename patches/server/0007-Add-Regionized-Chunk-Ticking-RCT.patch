     }
+
+    // =========================================================
+    // Performance: Regionized Chunk Ticking (RCT)
+    // =========================================================
+
+    /**
+     * Regionized Chunk Ticking (RCT) を有効にするかどうか。
+     * プレイヤーが離れた位置にいる場合、それぞれのチャンク領域を並列に tick する。
+     * DivineMC/CanvasMC の実装を参考にした SuperVertex 独自最適化。
+     * 低クロック多コア CPU での大人数サーバーに効果的。
+     */
+    public static boolean regionizedChunkTicking = true;
+
+    private static void regionizedChunkTicking() {
+        regionizedChunkTicking = getBoolean("performance.regionized-chunk-ticking", regionizedChunkTicking);
+    }
 }
